# ── Clerk Auth ────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Database ──────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key for Plaid access tokens at rest. Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-output-of-openssl-rand-hex-32

# ── Plaid ─────────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_or_development_secret
# sandbox | development | production
PLAID_ENV=sandbox

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
